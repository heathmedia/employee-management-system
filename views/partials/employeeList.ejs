<table id="employeeList" class="employeeList">
    <tbody>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Department</th>
            <th>Role</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Join Date</th>
            <th>Location</th>
            <% if (locals.user.role === 'admin') { %>
                <th></th>
            <% } %>
        </tr>
<% employees.forEach( employee => { %>
    <tr>
        <td><%= employee.fname %></td>
        <td><%= employee.lname %></td>
        <td><%= DEPARTMENTS[employee.department] %></td>
        <td><%= employee.role %></td>
        <td><%= employee.email %></td>
        <td><%= employee.phone %></td>
        <td><%= employee.joinDate %></td>
        <td><%= employee.location %></td>
        <% if (locals.user.role === 'admin') { %>
            <td class="whitespace-nowrap">
                <div class="flex gap-2">
                <button class="edit-btn" title="Edit" aria-label="Edit employee" class="btn-regular min-w-8" onclick="location.href = '/editEmployee/<%= employee.id %>'">
                    <i class="fa-solid fa-pencil"></i>
                </button>
                <button class="delete-btn" title="Delete" aria-label="Delete employee" class="btn-regular min-w-8" onclick="confirmEmployeeDelete(
                '<%= employee.id %>','<%= employee.fname %>','<%= employee.lname %>')">
                    <i class="fa-solid fa-trash"></i>
                </button>
                </div>
            </td>
        <% } %>
    </tr>
<% }) %>
</tbody>
</table>