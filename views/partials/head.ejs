<!-- views/partials/head.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' — EMS' : 'EMS' %></title>
  
  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Font Awesome CDN -->
   <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { brand: '#1a1a2e' },
          fontFamily: {
            sans: ['DM Sans', 'sans-serif'],
            serif: ['DM Serif Display', 'serif']
          }
        }
      }
    }
  </script>

  <style type="text/tailwindcss">
    body {
        @apply bg-gray-50 text-gray-900 font-sans;
    }

    h1 { @apply text-3xl font-normal mb-4; }
    h2 { @apply text-2xl font-normal mb-3; }
    h3 { @apply text-lg font-medium mb-2; }

    p  { @apply text-base leading-relaxed text-gray-700 mb-3; }
    a  { @apply text-blue-600 hover:underline; }

    label  { @apply block text-sm font-medium text-gray-700 mb-1; }
    input  { @apply w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500; }
    select { @apply w-full border border-gray-300 rounded-md px-3 py-2 text-sm; }

    table  { @apply w-full text-sm border-collapse; }
    thead  { @apply bg-gray-100 text-gray-600 uppercase text-xs tracking-wide; }
    th, td { @apply px-4 py-3 text-left border-b border-gray-200; }
    tbody tr:hover { @apply bg-gray-50; }

    .btn-submit { @apply no-underline bg-slate-900 hover:bg-slate-700 hover:no-underline text-white text-sm font-medium rounded-lg py-2.5 transition-colors; }
    .btn-secondary { @apply text-center no-underline border border-slate-200 bg-slate-50 hover:border-indigo-400 hover:text-indigo-600 hover:bg-indigo-50 hover:no-underline text-slate-500 text-sm rounded-lg py-2 transition-colors; }
    .btn-regular { @apply text-center no-underline text-lg border border-slate-200 bg-slate-50 hover:border-indigo-400 hover:text-indigo-600 hover:bg-indigo-50 hover:no-underline text-slate-500 text-xs rounded-lg py-2 transition-colors; }

    input, select { @apply border border-slate-200 bg-slate-50 rounded-lg px-3 py-2.5 text-sm text-slate-900 outline-none focus:border-indigo-400 focus:bg-white transition-colors; }
    input[type="button"], input[type="submit"] { @apply cursor-pointer; }

    .error-box { @apply bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3 mb-5; }
    .message-box { @apply bg-green-50 border border-green-200 text-green-600 text-sm rounded-lg px-4 py-3 mb-5; }

    .header-primary { @apply font-serif text-2xl text-slate-900 mb-7 leading-snug; }
    .header-secondary { @apply text-xs tracking-widest uppercase text-slate-400 mb-5; }

    .label-primary { @apply text-xs font-medium text-slate-500 mb-1.5; }

    nav a { @apply text-white px-2; }

    .content { @apply max-w-7xl mx-auto p-6; }
    .employeeList { @apply my-4; }

    .formGrid2ColContainer { @apply grid grid-cols-2 gap-x-8 gap-y-5; }
    .fromGridRow2Col { @apply flex flex-col gap-1.5; }
    .fromGridRow2Col label { @apply text-xs font-medium text-slate-500; }
    .fromGridRow2Col input { @apply border border-slate-200 rounded-lg px-3 py-2.5 text-sm outline-none focus:border-indigo-400; }
    
    .recentHiresContainer { @apply flex grid grid-cols-5 gap-x-2; }
    .recentHire {@apply grid border rounded-md border-slate-200 p-4; }
    .recentHireName { @apply text-xl font-medium; }
    .recentHireRole { @apply text-sm uppercase;}
    .recentHireDepartment { @apply text-sm uppercase;}
    .recentHireEmail { @apply text-sm items-center; }
    .recentHirePhone { @apply text-sm items-center; }
    .recentHireLocation { @apply text-sm items-center; }
    .recentHireJoinDate { @apply text-xs uppercase; }
    
</style>
</head>