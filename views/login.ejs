<%- include('./partials/head', { pageTitle: 'Sign In' }) %>

<div class="flex min-h-screen font-sans">

  <!-- Left panel -->
  <div class="hidden md:flex w-5/12 bg-slate-900 flex-col justify-between p-10">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 bg-indigo-500 rounded-lg flex items-center justify-center text-white text-sm font-medium">E</div>
      <span class="text-white text-sm font-medium tracking-wide">EMS Portal</span>
    </div>

    <div>
      <h1 class="font-serif text-4xl text-white leading-snug mb-3">
        Manage your team <span class="text-indigo-400 italic">effortlessly</span>
      </h1>
      <p class="text-slate-500 text-sm leading-relaxed">
        One place for employee records,<br>roles, and access control.
      </p>
    </div>

    <div class="text-slate-600 text-xs">Scott Heath &copy; 2025</div>
  </div>

  <!-- Right panel -->
  <div class="flex-1 flex items-center justify-center bg-slate-50 p-8">
    <div class="bg-white border border-slate-200 rounded-2xl p-9 w-full max-w-sm">

      <p class="header-secondary">Welcome back</p>
      <h2 class="header-primary">Sign in to your account</h2>

      <% if (locals.error) { %>
        <div class="msg-error">
          <%= locals.error %>
        </div>
      <% } %>

      <form method="POST" action="/login">
        <div class="mb-4">
          <label class="label-primary">Email address</label>
          <input
            type="email"
            name="email"
            placeholder="you@acme.com"
            required
            autocomplete="email"
            class=""
          >
        </div>

        <div class="mb-5">
          <label class="label-primary">Password</label>
          <input
            type="password"
            name="password"
            placeholder="••••••••"
            required
            autocomplete="current-password"
            class=""
          >
        </div>

        <button
          type="submit"
          class="btn-submit w-full"
        >
          Sign in
        </button>
      </form>

      <div class="flex items-center gap-3 my-5">
        <div class="flex-1 h-px bg-slate-200"></div>
        <span class="text-xs text-slate-400">or create an account</span>
        <div class="flex-1 h-px bg-slate-200"></div>
      </div>

      <div class="grid grid-cols-1 gap-2">
        <a href="/signup"
          class="btn-secondary"
        >
          Join
        </a> 
      </div>

      <p class="text-center text-xs text-slate-400 mt-5">
        Need help? <a href="#" class="text-indigo-500 hover:underline">Contact IT support</a>
      </p>

    </div>
  </div>
</div>

<%- include('./partials/foot') %>